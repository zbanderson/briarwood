# Briarwood API Keys — copy to .env (gitignored) and fill in.
# Load with: `set -a; source .env; set +a`  (or use direnv / a dotenv loader)

# ---------- LLM (required for non-fallback agent) ----------
# OpenAI powers the agent LLM client and local_intelligence extractor.
OPENAI_API_KEY=

# Anthropic (optional — Claude-backed agent path if you wire it)
ANTHROPIC_API_KEY=

# ---------- Property data ----------
# ATTOM: county-level sales comps + ownership. Required for comp enrichment.
ATTOM_API_KEY=

# ---------- Town research (Phase C auto-research) ----------
# Pick ONE provider. First non-empty wins (tavily -> serper -> brave).
TAVILY_API_KEY=
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=

# ---------- Agent tuning (optional) ----------
# Model used by briarwood/agent/llm.py (default: gpt-4o-mini)
BRIARWOOD_AGENT_MODEL=

# Wall-clock budget for auto-research per turn, in seconds (default: 30)
BRIARWOOD_AGENT_RESEARCH_BUDGET_S=

# ---------- Cost guardrails (per-process session) ----------
# Hard caps — requests past the cap raise BudgetExceeded and no-op.
BRIARWOOD_BUDGET_ATTOM_CALLS=50
BRIARWOOD_BUDGET_WEBSEARCH_CALLS=20
BRIARWOOD_BUDGET_OPENAI_USD=1.00

# Local intelligence extractor model / reasoning effort
BRIARWOOD_LOCAL_INTELLIGENCE_MODEL=
BRIARWOOD_LOCAL_INTELLIGENCE_REASONING=

# ---------- Pipeline toggles (optional) ----------
# Enable geocoding calls in the main runner (default off for reproducibility)
BRIARWOOD_ENABLE_GEOCODING=
# Disable the dash app's manual-address geocoder
BRIARWOOD_DISABLE_MANUAL_GEOCODING=
# Override path to NJ tax dataset used by property_data_quality
BRIARWOOD_NJ_TAX_PATH=
